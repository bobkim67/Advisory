class ALMTacticalEnv(gym.Env):
    """
    적립비율(Funding Ratio)과 턴오버 제약을 포함한 커스텀 강화학습 환경
    """
    def __init__(self, asset_returns: np.ndarray, macro_features: np.ndarray, 
                 regime_probs: np.ndarray, liability_returns: np.ndarray, 
                 initial_funding_ratio: float = 1.0):
        super(ALMTacticalEnv, self).__init__()
        
        self.n_assets = asset_returns.shape
        self.current_step = 0
        self.max_steps = len(asset_returns) - 1
        
        self.asset_returns = asset_returns
        self.liability_returns = liability_returns
        self.macro_features = macro_features
        self.regime_probs = regime_probs
        
        self.current_weights = np.ones(self.n_assets) / self.n_assets
        self.funding_ratio = initial_funding_ratio
        
        # Action: [-1, 1] 범위의 실수 출력 (내부에서 Softmax로 변환)
        self.action_space = spaces.Box(low=-1.0, high=1.0, shape=(self.n_assets,), dtype=np.float32)
        
        # State: [자산수익, 거시배경, 국면확률, 현재비중, 적립비율]
        obs_dim = self.n_assets + macro_features.shape + regime_probs.shape + self.n_assets + 1
        self.observation_space = spaces.Box(low=-np.inf, high=np.inf, shape=(obs_dim,), dtype=np.float32)

    def _get_obs(self):
        obs = np.concatenate([
            self.asset_returns[self.current_step],
            self.macro_features[self.current_step],
            self.regime_probs[self.current_step],
            self.current_weights,
            [self.funding_ratio])
        return obs

    def step(self, action: np.ndarray):
        # 1. Softmax Projection (Long-only, sum=1 보장)
        exp_action = np.exp(action)
        target_weights = exp_action / np.sum(exp_action)
        
        # 2. 턴오버 및 거래비용 산출
        turnover = np.sum(np.abs(target_weights - self.current_weights))
        transaction_cost = turnover * 0.0015  # 15bp 가정
        
        # 3. 포트폴리오 수익 및 부채 갱신
        port_return = np.dot(target_weights, self.asset_returns[self.current_step]) - transaction_cost
        liab_return = self.liability_returns[self.current_step]
        
        # Funding ratio 업데이트 로직 (간단한 형태)
        self.funding_ratio = self.funding_ratio * ((1 + port_return) / (1 + liab_return))
        
        # 4. ALM Reward 함수 적용
        # Surplus return 달성 보상 - 적립비율 1 미만 시 비선형 패널티 - 과도한 턴오버 제어
        reward = (port_return - liab_return) - 5.0 * max(0, 1.0 - self.funding_ratio)**2 - 0.5 * turnover
        
        self.current_weights = target_weights
        self.current_step += 1
        done = self.current_step >= self.max_steps
        
        return self._get_obs(), reward, done, False, {}

